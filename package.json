{
  "name": "sculpt",
  "version": "0.1.0",
  "description": "We don't build agents. We sculpt them.",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=packages/chisel",
    "build": "npm run build --workspace=packages/chisel",
    "test": "npm test --workspaces",
    "lint": "eslint packages/*/src",
    "db:generate": "npm run db:generate --workspace=packages/db",
    "db:push": "npm run db:push --workspace=packages/db",
    "db:migrate": "npm run db:migrate --workspace=packages/db",
    "workshop:dev": "npm run dev --workspace=packages/workshop",
    "workshop:build": "npm run build --workspace=packages/workshop",
    "workshop:start": "npm run start --workspace=packages/workshop"
  },
  "keywords": [
    "ai-agents",
    "sculpting",
    "subtractive",
    "llm",
    "claude",
    "agent-builder"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}
