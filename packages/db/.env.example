# PostgreSQL connection string
# Get a free database from https://neon.tech or https://supabase.com
DATABASE_URL="postgresql://user:password@host:5432/sculpt?sslmode=require"

# AES-256 encryption key for API keys (32 bytes = 64 hex chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="your-64-char-hex-string-here"
